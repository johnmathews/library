{
  "extends": "./tsconfig.app.json",

  // Override to include only test files and clear exclusions.
  // Application code imported in tests is automatically included via module
  // resolution, but ambient declarations (src/types) must be listed.
  "include": ["src/**/__tests__/*", "src/types/**/*.d.ts", "env.d.ts"],
  "exclude": [],

  "compilerOptions": {
    // Vitest runs the tests in jsdom, which mirrors the browser environment.
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node", "jsdom"],

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo"
  }
}

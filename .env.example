# Library configuration — copy to `.env` next to docker-compose.yml.
#
# Every setting the application reads (src/library/config.py) is listed
# here with its default. Commented-out lines show the default value;
# uncomment and change what you need. docker-compose passes this file to
# the api, worker and migrate containers (env_file) and also uses it for
# ${...} interpolation in docker-compose.yml itself.

# --- Core -------------------------------------------------------------

# SQLAlchemy database URL (asyncpg driver). The default matches the
# compose-internal Postgres service. Procrastinate (job queue) derives its
# own libpq URL from this.
#LIBRARY_DATABASE_URL=postgresql+asyncpg://library:library@db:5432/library

# Root of the document store: originals/ and derived/ live under it.
# Inside the containers this is the `library_data` volume — do not change
# it for a compose deployment.
#LIBRARY_DATA_DIR=/data

# Free-form deployment label (e.g. production, staging, dev).
#LIBRARY_ENVIRONMENT=production

# Upload/ingest size cap in bytes (default 100 MiB). Applies to web
# uploads, the consume folder, email attachments and MCP ingestion.
#LIBRARY_MAX_UPLOAD_BYTES=104857600

# Public base URL of the web app (no trailing slash). Used to deep-link
# Pushover push notifications back to the document they refer to, so tapping
# a notification opens it in the app. Strongly recommended in production —
# unset = notifications arrive with no link (and the app logs a warning at
# startup). Set it to however you reach the web app from your phone.
LIBRARY_PUBLIC_BASE_URL=https://library.example.com

# Directory containing the built Vue SPA (index.html + assets/), relative
# to the process working directory. The Docker image bakes the build into
# /app/frontend/dist, which the default resolves to — leave it alone.
#LIBRARY_FRONTEND_DIST=frontend/dist

# --- Sessions and cookies (docs/api.md §1.9) ---------------------------

# Browser sessions expire after this many days of inactivity (sliding).
#LIBRARY_SESSION_TTL_DAYS=30

# Session/CSRF cookies carry the Secure flag (HTTPS only). Keep true in
# production behind a TLS reverse proxy; set false only for plain-HTTP
# testing — browsers drop Secure cookies over http://.
#LIBRARY_COOKIE_SECURE=true

# --- OCR (docs/ingestion.md, "OCR") ------------------------------------

# Tesseract language packs (-l value). The image ships nld+eng tessdata;
# add packs to the Dockerfile before listing them here.
#LIBRARY_OCR_LANGUAGES=nld+eng

# Below this mean word confidence (0-100), a Tesseract result is retried
# through the neural photo path (RapidOCR) and the better text kept.
#LIBRARY_OCR_CONFIDENCE_THRESHOLD=65.0

# A PDF text layer counts as usable when it averages at least this many
# characters per page (born-digital PDFs skip OCR entirely).
#LIBRARY_TEXT_LAYER_MIN_CHARS_PER_PAGE=50

# --- Claude metadata extraction (docs/ingestion.md, "Extraction") ------

# Anthropic API key. Unset = extraction is skipped (documents still index
# and stay searchable by OCR text).
#LIBRARY_ANTHROPIC_API_KEY=sk-ant-...

# Master switch for the extraction stage.
#LIBRARY_EXTRACTION_ENABLED=true

# Primary model, and the model low-confidence documents escalate to.
#LIBRARY_EXTRACTION_MODEL=claude-haiku-4-5
#LIBRARY_EXTRACTION_ESCALATION_MODEL=claude-sonnet-4-6

# Thin-scan density trigger: when OCR ran (ocr_confidence set) and the OCR
# text averages fewer than this many chars per page, the primary extraction
# call sends the original file (vision) instead of the thin text. Born-digital
# documents (ocr_confidence NULL) are never affected. 0 disables the trigger.
#LIBRARY_EXTRACTION_VISION_MIN_CHARS_PER_PAGE=800

# Estimated daily spend cap (USD). At/over budget, extraction is skipped
# (reason "budget") until the next UTC day.
#LIBRARY_EXTRACTION_DAILY_BUDGET_USD=5.0

# --- Markdown layer (docs/ingestion.md, "Markdown layer") -------------

# Vision rendering of each document page; feeds embeddings and Ask citations.
# Uses LIBRARY_ANTHROPIC_API_KEY (above); layer is skipped when the key is absent.
#LIBRARY_MARKDOWN_ENABLED=true

# Vision model for markdown generation.
#LIBRARY_MARKDOWN_MODEL=claude-haiku-4-5

# Daily spend cap (USD) for the markdown stage, independent of the extraction
# budget. At/over budget, the stage is skipped (reason "budget") until the
# next UTC day.
#LIBRARY_MARKDOWN_DAILY_BUDGET_USD=5.0

# Max pages rendered and sent per document (pages beyond this cap embed from
# ocr_text without page provenance).
#LIBRARY_MARKDOWN_MAX_PAGES=20

# Pages per vision call (batched; page-number offset applied between batches).
#LIBRARY_MARKDOWN_PAGE_BATCH=10

# Long-side cap (pixels) for page images sent to the model. Higher = more
# detail but larger tokens; 1600 is enough for table fidelity.
#LIBRARY_MARKDOWN_IMAGE_LONG_SIDE_PX=1600

# --- Background worker / job queue (docs/ingestion.md, "Job queue") -----

# Documents the Procrastinate worker processes at once. Default 1 (serial).
# Raising it drains ingestion bursts faster but multiplies peak worker RAM
# (parallel OCR subprocesses + embedder batches) — only raise it with host
# headroom to spare.
#LIBRARY_WORKER_CONCURRENCY=1

# Crash recovery: a hard-killed worker (OOM/redeploy mid-stage) strands its
# in-flight document. Every N minutes the sweep_stalled_jobs task re-enqueues
# process_document jobs whose worker heartbeat is older than the timeout below;
# the pipeline resumes idempotently. 0 disables the sweep.
#LIBRARY_STALLED_JOB_SWEEP_MINUTES=5

# How long since a worker's last heartbeat before its in-flight job is deemed
# stalled. Kept well above Procrastinate's ~10 s heartbeat so a live worker
# mid-OCR is never swept.
#LIBRARY_STALLED_JOB_HEARTBEAT_SECONDS=60.0

# How long a dead worker's row survives before Procrastinate prunes it at the
# next worker startup. The sweep can only see a stranded job while its worker
# row exists, so this stays high (24 h) — otherwise a redeploy would delete the
# crashed worker's row before the sweep runs and hide the job forever.
#LIBRARY_STALLED_WORKER_PRUNE_SECONDS=86400.0

# Daily auto-backfill of documents whose extraction/markdown was skipped by the
# daily LLM budget (the budget resets daily). Off by default because it spends:
# enable it to have the budget-skipped backlog re-enqueued at 03:17 UTC.
#LIBRARY_BUDGET_BACKFILL_ENABLED=false

# --- Semantic search / Ask (docs/ask.md) -------------------------------

# Master switch for the embed pipeline stage. Off = no semantic index
# (full-text search still works); you can then drop the `embedder` service
# and run the stack in ~4 GB.
#LIBRARY_EMBEDDING_ENABLED=true

# The local bge-m3 embedding sidecar (text-embeddings-inference). The
# default matches the compose-internal `embedder` service.
#LIBRARY_EMBEDDING_SERVICE_URL=http://embedder:80
#LIBRARY_EMBEDDING_MODEL_NAME=bge-m3

# Chunking: target characters per chunk and overlap carried between chunks.
#LIBRARY_EMBEDDING_CHUNK_CHARS=1800
#LIBRARY_EMBEDDING_CHUNK_OVERLAP=200

# Documents returned by hybrid retrieval for an Ask query.
#LIBRARY_RETRIEVE_TOP_K=10

# Ask answering model and loop bounds. Ask needs LIBRARY_ANTHROPIC_API_KEY
# (above); without it POST /api/ask returns 503. Cost is recorded per turn in
# ask_turns, not gated.
#LIBRARY_ASK_MODEL=claude-opus-4-8
# Cheap model that names a new conversation from its first Q&A exchange; must
# have a MODEL_PRICING_USD_PER_MTOK row. Failure keeps the placeholder title.
#LIBRARY_ASK_TITLE_MODEL=claude-haiku-4-5
#LIBRARY_ASK_MAX_TOOL_TURNS=4
#LIBRARY_ASK_MAX_ANSWER_TOKENS=1024
#LIBRARY_ASK_HISTORY_TURNS=3

# Document series + comparative queries (docs/ask.md). Min members before
# series stats are reported; "typical" band half-width vs median; trend
# flat-band on first->last change.
#LIBRARY_SERIES_MIN_DOCUMENTS=3
#LIBRARY_SERIES_TYPICAL_PCT=0.10
#LIBRARY_SERIES_FLAT_PCT=0.05

# --- FX rates (docs/admin.md §1.2.6) -----------------------------------
# The admin "Fetch rate" affordance calls this keyless provider for the
# live USD-per-unit rate (open.er-api.com returns USD->X; it is inverted).
# Manual entry always works as a fallback if the provider is unreachable.
#LIBRARY_FX_API_URL=https://open.er-api.com/v6/latest
#LIBRARY_FX_API_TIMEOUT_S=10.0

# --- Consume folder watcher (docs/ingestion.md, "Consume folder") ------

# Directory watched for dropped files. The compose worker sets it to
# /data/consume (inside the library_data volume); bind-mount your
# Syncthing-synced scan folder over it in production. Unset = watcher off.
#LIBRARY_CONSUME_DIR=/data/consume

# Where successfully ingested files are archived (consumed/YYYY/MM/) and
# rejected files are parked. Both default to siblings of the consume dir
# (<parent of consume dir>/consumed and .../failed) so the watched folder
# holds only pending items. Set them explicitly when the consume dir is the
# root of its own mount — the sibling default would land outside the
# persistent volume. Legacy trees inside the consume dir are auto-migrated
# to these locations at worker startup.
#LIBRARY_CONSUMED_DIR=/data/consumed
#LIBRARY_FAILED_DIR=/data/failed

# inotify does not cross NFS/SMB mounts — force polling for those.
#LIBRARY_CONSUME_FORCE_POLLING=false

# Poll cadence (seconds) when force-polling.
#LIBRARY_CONSUME_POLL_INTERVAL_S=2.0

# A file's size+mtime must be unchanged this long before it is ingested
# (protects against half-copied files).
#LIBRARY_CONSUME_STABILITY_S=3.0

# What happens to a successfully ingested file: "archive" moves it to
# consumed/YYYY/MM/ under LIBRARY_CONSUMED_DIR, "delete" unlinks it.
#LIBRARY_CONSUME_ON_SUCCESS=archive

# Username that owns consume-folder and paperless-import documents (these
# channels have no inherent uploader). Set it so the owner-as-recipient
# fallback can fire for scans/imports that name no recipient of their own.
# Unset = such documents stay unowned.
#LIBRARY_IMPORT_DEFAULT_OWNER=john

# --- Email-in ingestion (docs/ingestion.md, "Email-in") ----------------

# IMAP host. Unset = email poller off. Use a dedicated mailbox and an
# app password (see the provider table in docs/ingestion.md).
#LIBRARY_EMAIL_HOST=imap.example.org
#LIBRARY_EMAIL_PORT=993
#LIBRARY_EMAIL_USERNAME=library@example.org
#LIBRARY_EMAIL_PASSWORD=app-password-here

# IMAP socket timeout in seconds: bounds connect and every subsequent
# command so a wedged server can never hang a poll.
#LIBRARY_EMAIL_IMAP_TIMEOUT_SECONDS=60.0

# Folder polled for new mail, and where handled messages are moved
# (created if missing).
#LIBRARY_EMAIL_FOLDER=INBOX
#LIBRARY_EMAIL_PROCESSED_FOLDER=Library/Processed

# Poll cadence in minutes (1-59).
#LIBRARY_EMAIL_POLL_MINUTES=10

# Comma-separated sender allowlist (case-insensitive). Empty accepts mail
# from anyone — set this whenever the address is guessable.
#LIBRARY_EMAIL_ALLOWED_SENDERS=you@example.org,partner@example.org

# Username that owns email-ingested documents whose sender matches no user's
# forwarding addresses (Settings → Notifications). Such documents notify their
# owner; unset leaves unmatched mail unowned (and silent).
#LIBRARY_EMAIL_DEFAULT_OWNER=

# Deterministic noise gate for email attachments: quietly filters signature
# logos, tracking pixels/icons, decoration images (logos/banners — two of
# three signals must agree: filename, size, shape), and calendar/vCard/PKCS7/
# TNEF parts before they become documents (recorded in the decision trace,
# never surfaced). Thresholds are conservative and a decode failure never
# drops; set enabled=false to ingest every attachment exactly as before.
#LIBRARY_EMAIL_FILTER_NOISE_ENABLED=true
#LIBRARY_EMAIL_FILTER_TINY_IMAGE_MAX_BYTES=4096
#LIBRARY_EMAIL_FILTER_TINY_IMAGE_MAX_EDGE_PX=64
#LIBRARY_EMAIL_FILTER_DECORATION_MAX_BYTES=65536
#LIBRARY_EMAIL_FILTER_DECORATION_MAX_EDGE_PX=384

# Optional per-email LLM label pass: one Anthropic call per email judges the
# surviving attachments AND the body (each keep|probably_noise — probably_noise
# is still ingested, just flagged needs_review, never dropped) plus the whole
# email (file|hold — hold routes the email to the /held-emails review queue;
# fail-open, any label failure files as before). OFF by default — it spends
# money; enabling it also requires LIBRARY_ANTHROPIC_API_KEY. Spend is
# budget-gated like extraction ($2/day, summed from email_label_completed
# events). See the enablement recipe in docs/runbooks/email-triage.md.
#LIBRARY_EMAIL_LABEL_ENABLED=false
#LIBRARY_EMAIL_LABEL_MODEL=claude-haiku-4-5
#LIBRARY_EMAIL_LABEL_DAILY_BUDGET_USD=2.0
#LIBRARY_EMAIL_LABEL_BODY_SNIPPET_CHARS=1000

# Hold-for-review (docs/ingestion.md, "Held for review"): an email judged not
# library-worthy (LLM hold verdict, thin body-only mail, nothing ingested,
# unknown sender) is HELD — a durable held_emails row plus a move to the Held
# folder — for a human to ingest-anyway or dismiss in /held-emails, instead of
# being silently processed or left in the inbox. HOLD_ENABLED=false is the
# rollback lever (restores the pre-hold behaviour exactly); the two trigger
# flags gate their deterministic holds individually.
#LIBRARY_EMAIL_HOLD_ENABLED=true
#LIBRARY_EMAIL_HELD_FOLDER=Library/Held
#LIBRARY_EMAIL_HOLD_BELOW_SUBSTANCE=true
#LIBRARY_EMAIL_HOLD_UNKNOWN_SENDERS=true

# --- paperless-ngx import (docs/migration.md) --------------------------

# Defaults for `library import paperless` (both can also be given as
# --url/--token flags). Not needed at runtime.
#LIBRARY_PAPERLESS_URL=http://paperless.lan:8000
#LIBRARY_PAPERLESS_TOKEN=paperless-api-token

# Library configuration — copy to `.env` next to docker-compose.yml.
#
# Every setting the application reads (src/library/config.py) is listed
# here with its default. Commented-out lines show the default value;
# uncomment and change what you need. docker-compose passes this file to
# the api, worker and migrate containers (env_file) and also uses it for
# ${...} interpolation in docker-compose.yml itself.

# --- Core -------------------------------------------------------------

# SQLAlchemy database URL (asyncpg driver). The default matches the
# compose-internal Postgres service. Procrastinate (job queue) derives its
# own libpq URL from this.
#LIBRARY_DATABASE_URL=postgresql+asyncpg://library:library@db:5432/library

# Root of the document store: originals/ and derived/ live under it.
# Inside the containers this is the `library_data` volume — do not change
# it for a compose deployment.
#LIBRARY_DATA_DIR=/data

# Free-form deployment label (e.g. production, staging, dev).
#LIBRARY_ENVIRONMENT=production

# Upload/ingest size cap in bytes (default 100 MiB). Applies to web
# uploads, the consume folder, email attachments and MCP ingestion.
#LIBRARY_MAX_UPLOAD_BYTES=104857600

# Directory containing the built Vue SPA (index.html + assets/), relative
# to the process working directory. The Docker image bakes the build into
# /app/frontend/dist, which the default resolves to — leave it alone.
#LIBRARY_FRONTEND_DIST=frontend/dist

# --- Sessions and cookies (docs/api.md §1.9) ---------------------------

# Browser sessions expire after this many days of inactivity (sliding).
#LIBRARY_SESSION_TTL_DAYS=30

# Session/CSRF cookies carry the Secure flag (HTTPS only). Keep true in
# production behind a TLS reverse proxy; set false only for plain-HTTP
# testing — browsers drop Secure cookies over http://.
#LIBRARY_COOKIE_SECURE=true

# --- OCR (docs/ingestion.md, "OCR") ------------------------------------

# Tesseract language packs (-l value). The image ships nld+eng tessdata;
# add packs to the Dockerfile before listing them here.
#LIBRARY_OCR_LANGUAGES=nld+eng

# Below this mean word confidence (0-100), a Tesseract result is retried
# through the neural photo path (RapidOCR) and the better text kept.
#LIBRARY_OCR_CONFIDENCE_THRESHOLD=65.0

# A PDF text layer counts as usable when it averages at least this many
# characters per page (born-digital PDFs skip OCR entirely).
#LIBRARY_TEXT_LAYER_MIN_CHARS_PER_PAGE=50

# --- Claude metadata extraction (docs/ingestion.md, "Extraction") ------

# Anthropic API key. Unset = extraction is skipped (documents still index
# and stay searchable by OCR text).
#LIBRARY_ANTHROPIC_API_KEY=sk-ant-...

# Master switch for the extraction stage.
#LIBRARY_EXTRACTION_ENABLED=true

# Primary model, and the model low-confidence documents escalate to.
#LIBRARY_EXTRACTION_MODEL=claude-haiku-4-5
#LIBRARY_EXTRACTION_ESCALATION_MODEL=claude-sonnet-4-6

# Estimated daily spend cap (USD). At/over budget, extraction is skipped
# (reason "budget") until the next UTC day.
#LIBRARY_EXTRACTION_DAILY_BUDGET_USD=5.0

# --- Markdown layer (docs/ingestion.md, "Markdown layer") -------------

# Vision rendering of each document page; feeds embeddings and Ask citations.
# Uses LIBRARY_ANTHROPIC_API_KEY (above); layer is skipped when the key is absent.
#LIBRARY_MARKDOWN_ENABLED=true

# Vision model for markdown generation.
#LIBRARY_MARKDOWN_MODEL=claude-haiku-4-5

# Daily spend cap (USD) for the markdown stage, independent of the extraction
# budget. At/over budget, the stage is skipped (reason "budget") until the
# next UTC day.
#LIBRARY_MARKDOWN_DAILY_BUDGET_USD=5.0

# Max pages rendered and sent per document (pages beyond this cap embed from
# ocr_text without page provenance).
#LIBRARY_MARKDOWN_MAX_PAGES=20

# Pages per vision call (batched; page-number offset applied between batches).
#LIBRARY_MARKDOWN_PAGE_BATCH=10

# Long-side cap (pixels) for page images sent to the model. Higher = more
# detail but larger tokens; 1600 is enough for table fidelity.
#LIBRARY_MARKDOWN_IMAGE_LONG_SIDE_PX=1600

# --- Semantic search / Ask (docs/ask.md) -------------------------------

# Master switch for the embed pipeline stage. Off = no semantic index
# (full-text search still works); you can then drop the `embedder` service
# and run the stack in ~4 GB.
#LIBRARY_EMBEDDING_ENABLED=true

# The local bge-m3 embedding sidecar (text-embeddings-inference). The
# default matches the compose-internal `embedder` service.
#LIBRARY_EMBEDDING_SERVICE_URL=http://embedder:80
#LIBRARY_EMBEDDING_MODEL_NAME=bge-m3

# Chunking: target characters per chunk and overlap carried between chunks.
#LIBRARY_EMBEDDING_CHUNK_CHARS=1800
#LIBRARY_EMBEDDING_CHUNK_OVERLAP=200

# Documents returned by hybrid retrieval for an Ask query.
#LIBRARY_RETRIEVE_TOP_K=10

# Ask answering model and loop bounds. Ask needs LIBRARY_ANTHROPIC_API_KEY
# (above); without it POST /api/ask returns 503. Cost is recorded in
# ask_logs, not gated.
#LIBRARY_ASK_MODEL=claude-sonnet-4-6
#LIBRARY_ASK_MAX_TOOL_TURNS=4
#LIBRARY_ASK_MAX_ANSWER_TOKENS=1024

# --- Consume folder watcher (docs/ingestion.md, "Consume folder") ------

# Directory watched for dropped files. The compose worker sets it to
# /data/consume (inside the library_data volume); bind-mount your
# Syncthing-synced scan folder over it in production. Unset = watcher off.
#LIBRARY_CONSUME_DIR=/data/consume

# inotify does not cross NFS/SMB mounts — force polling for those.
#LIBRARY_CONSUME_FORCE_POLLING=false

# Poll cadence (seconds) when force-polling.
#LIBRARY_CONSUME_POLL_INTERVAL_S=2.0

# A file's size+mtime must be unchanged this long before it is ingested
# (protects against half-copied files).
#LIBRARY_CONSUME_STABILITY_S=3.0

# What happens to a successfully ingested file: "archive" moves it to
# consumed/YYYY/MM/ inside the consume dir, "delete" unlinks it.
#LIBRARY_CONSUME_ON_SUCCESS=archive

# --- Email-in ingestion (docs/ingestion.md, "Email-in") ----------------

# IMAP host. Unset = email poller off. Use a dedicated mailbox and an
# app password (see the provider table in docs/ingestion.md).
#LIBRARY_EMAIL_HOST=imap.example.org
#LIBRARY_EMAIL_PORT=993
#LIBRARY_EMAIL_USERNAME=library@example.org
#LIBRARY_EMAIL_PASSWORD=app-password-here

# Folder polled for new mail, and where handled messages are moved
# (created if missing).
#LIBRARY_EMAIL_FOLDER=INBOX
#LIBRARY_EMAIL_PROCESSED_FOLDER=Library/Processed

# Poll cadence in minutes (1-59).
#LIBRARY_EMAIL_POLL_MINUTES=10

# Comma-separated sender allowlist (case-insensitive). Empty accepts mail
# from anyone — set this whenever the address is guessable.
#LIBRARY_EMAIL_ALLOWED_SENDERS=you@example.org,partner@example.org

# --- paperless-ngx import (docs/migration.md) --------------------------

# Defaults for `library import paperless` (both can also be given as
# --url/--token flags). Not needed at runtime.
#LIBRARY_PAPERLESS_URL=http://paperless.lan:8000
#LIBRARY_PAPERLESS_TOKEN=paperless-api-token
